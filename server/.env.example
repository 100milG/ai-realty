# Database Configuration
# Replace with your actual database credentials
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/ai_realty?schema=public"

# JWT Authentication Secret
# Generate a secure random string for production
JWT_SECRET="your_jwt_secret_here"

# Server Port
PORT=5000

# --- External APIs ---

# OpenAI API (For AI Chat and Insights)
OPENAI_API_KEY=""

# Stripe (For Payments and Subscriptions)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cloudinary (For Image/Media Storage)
CLOUDINARY_URL=""

# Resend / SendGrid (For Email Notifications)
RESEND_API_KEY=""

# Geoapify (For Geocoding and Autocomplete)
GEOAPIFY_API_KEY=""
